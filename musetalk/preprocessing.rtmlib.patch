+_dwpose_onnx = os.path.join("models", "dwpose", "dw-ll_ucoco_384.onnx")
+pose_model = RTMPose(_dwpose_onnx, model_input_size=(288, 384),
+                     backend="onnxruntime", device="cpu")
+
+def _dwpose_landmarks(frame):
+    """Return 133x2 COCO-wholebody keypoints for a single BGR frame, matching the
+    mmpose inference_topdown output that the rest of this module expects."""
+    h, w = frame.shape[:2]
+    bboxes = np.array([[0, 0, w, h]], dtype=np.float32)
+    keypoints, _scores = pose_model(frame, bboxes)
+    return keypoints
 
